            transition: filter 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
        .font-metal-brushed:hover {
            animation: metal-orange-breathe 2.4s infinite ease-in-out;
        }
    
        html, body, a, button, input, textarea, [role='button'], .cursor-pointer, .flip-card {
            cursor: none !important;
        }
        #custom-cursor {
            position: fixed;
            top: -100px;
            left: -100px;
            width: 24px;
            height: 24px;
            pointer-events: none;
            z-index: 9999999;
            display: block !important;
            opacity: 1 !important;
            will-change: transform;
            transform: translate(-50%, -50%);
        }
        #custom-cursor svg {
            width: 100%;
            height: 100%;
            transition: transform 0.18s ease;
            transform: scale(1);
        }
        #custom-cursor.expanded svg {
            transform: scale(1.18);
        }

        #cursor-glow {
            position: fixed;
            top: -100px;
            left: -100px;
            width: 40px;
            height: 40px;
            background: radial-gradient(circle, rgba(255, 94, 0, 0.3) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 9999998;
            transform: translate(-50%, -50%);
            transition: left 0.15s ease-out, top 0.15s ease-out, transform 0.2s;
            will-change: left, top;
        }
        #cursor-glow.expanded {
            transform: translate(-50%, -50%) scale(1.8);
            background: radial-gradient(circle, rgba(255, 94, 0, 0.5) 0%, transparent 70%);
        }
    
        .orange-hover-effect {
            transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
        .orange-hover-effect:hover {
            color: #FF5E00 !important;
            text-shadow: 0 0 10px rgba(255, 94, 0, 0.4);
            box-shadow: inset 5px 5px 10px #bebebe, inset -5px -5px 10px #ffffff !important;
            transform: scale(0.98);
        }
        .orange-hover-effect:hover .material-symbols-outlined {
            color: #FF5E00 !important;
        }
        
        .active-tab {
            color: #FF5E00 !important;
            box-shadow: inset 4px 4px 8px #bebebe, inset -4px -4px 8px #ffffff !important;
        }

        .fade-in {
            animation: fadeIn 0.3s ease-in-out;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes subtle-breathe {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-4px); }
        }
        .breathe-animation {
            animation: subtle-breathe 6s infinite ease-in-out;
        }

        @keyframes indicator-glow {
            0%, 100% {
                box-shadow: 0 0 6px #ff5e00, 0 0 12px #ff8033, inset 1px 1px 2px rgba(255,255,255,0.8);
