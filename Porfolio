                transform: scale(1);
            }
            50% {
                box-shadow: 0 0 14px #ff5e00, 0 0 24px #ff5e00, inset 1px 1px 2px rgba(255,255,255,1);
                opacity: 1;
                transform: scale(1.1);
            }
        }
        .online-glow-lamp {
            background: radial-gradient(circle at 35% 35%, #ffb380 0%, #ff5e00 70%, #b34200 100%);
            animation: indicator-glow 2.5s infinite ease-in-out;
        }

        .flip-card {
            background-color: transparent;
            perspective: 1000px;
        }
        .flip-card-inner {
            position: relative;
            width: 100%;
            height: 100%;
            text-align: center;
            transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            transform-style: preserve-3d;
        }
        .flip-card:hover .flip-card-inner {
            transform: rotateY(180deg);
        }
        .flip-card-front, .flip-card-back {
            position: absolute;
            width: 100%;
            height: 100%;
            -webkit-backface-visibility: hidden;
            backface-visibility: hidden;
            border-radius: 24px;
        }
        .flip-card-front {
            background-color: #e0e0e0;
        }
        .flip-card-back {
            background-color: #e0e0e0;
            transform: rotateY(180deg);
