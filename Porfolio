            background: linear-gradient(135deg, #ffffff 30%, #a3a3a3 75%, #737373 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(2px 2px 3px rgba(0, 0, 0, 0.22))
