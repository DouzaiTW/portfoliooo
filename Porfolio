        function formatCurrency(amount) {
            const rate = exchangeRates[currentCurrency];
            return `${currencySymbols[currentCurrency]}${(amount * rate).toLocaleString(undefined, { maximumFractionDigits: 2 })}`;
        }

        // 一鍵複製 Email 並觸發新擬態提示窗的交互大腦
        function copyEmailTrigger(btnElement) {
            const emailText = "open7496@gmail.com";
            navigator.clipboard.writeText(emailText).then(() => {
                const toast = document.getElementById('email-toast-box');
                const tag = document.getElementById('toast-msg-tag');
                
                tag.textContent = currentLang === 'en' ? 'Copied!' : '已複製！';
                tag.style.color = '#ffffff';
                tag.style.backgroundColor = '#FF5E00';
                
                toast.classList.remove('opacity-0', 'scale-90');
                toast.classList.add('opacity-100', 'scale-100');
                
                setTimeout(() => {
                    toast.classList.remove('opacity-100', 'scale-100');
                    toast.classList.add('opacity-0', 'scale-90');
                }, 2400);
            }).catch(err => {
                console.error('Could not copy text: ', err);
            });
        }

        // 智慧雙語切換控制中心
        function toggleLanguage() {
            currentLang = currentLang === 'en' ? 'zh' : 'en';
            document.getElementById('lang-text-display').textContent = currentLang === 'en' ? 'EN / 繁中' : '繁中 / EN';
            
            // 語系控制防碎裂
            const targetTitles = document.querySelectorAll('.dynamic-title-style');
            targetTitles.forEach(title => {
                if (currentLang === 'en') {
                    title.style.fontFamily = "'Space Grotesk', sans-serif";
                    title.style.letterSpacing = "0.1em";
                    title.style.fontWeight = "700";
                } else {
                    title.style.fontFamily = "'Noto Serif TC', serif";
                    title.style.letterSpacing = "0.18em";
                    title.style.fontWeight = "500";
                }
            });

            document.querySelectorAll('[data-t9n]').forEach(el => {
                const key = el.getAttribute('data-t9n');
                if (translations[currentLang][key]) {
                    if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
                        el.placeholder = translations[currentLang][key];
                    } else {
                        el.innerHTML = translations[translations[currentLang][key] ? currentLang : 'en'][key];
                    }
                }
            });

            // 多語系動態下載核心邏輯
            const resumeBtn = document.getElementById('dynamic-resume-btn');
            if (resumeBtn) {
                if (currentLang === 'en') {
                    resumeBtn.setAttribute('href', 'https://drive.google.com/uc?export=download&id=1Oku1jaxJqfQWYo4LibwiuMgWpBsFu6UC');
                    resumeBtn.setAttribute('download', "Yarong's Resume.pdf");
                } else {
                    resumeBtn.setAttribute('href', 'https://drive.google.com/uc?export=download&id=1JXQj5XkzQwBQPOaZJKeeQU1K3FhSA6Ao');
                    resumeBtn.setAttribute('download', 'Ya_Rong_Tsai_Resume_ZH.pdf');
                }
            }

            updateAdsContent();
        }

        function showView(viewId) {
            const portBtn = document.getElementById('nav-port-btn');
            const adsBtn = document.getElementById('nav-ads-btn');
            const expBtn = document.getElementById('nav-exp-btn');

            document.getElementById('view-main').classList.add('hidden');
            document.getElementById('view-ads').classList.add('hidden');
            document.getElementById('view-about').classList.add('hidden');

            portBtn.className = "text-gray-600 px-4 py-2 font-inter tracking-widest uppercase text-xs font-bold transition-all orange-hover-effect rounded-full";
            adsBtn.className = "text-gray-600 px-4 py-2 font-inter tracking-widest uppercase text-xs font-bold transition-all orange-hover-effect rounded-full";
            expBtn.className = "text-gray-600 px-4 py-2 font-inter tracking-widest uppercase text-xs font-bold transition-all orange-hover-effect rounded-full";

            if (viewId === 'main') {
                document.getElementById('view-main').classList.remove('hidden');
                portBtn.className = "text-[#FF5E00] px-4 py-2 font-inter tracking-widest uppercase text-xs font-bold neumorphic-sunken active-tab rounded-full";
            } else if (viewId === 'ads') {
                document.getElementById('view-ads').classList.remove('hidden');
                updateAdsContent();
                adsBtn.className = "text-[#FF5E00] px-4 py-2 font-inter tracking-widest uppercase text-xs font-bold neumorphic-sunken active-tab rounded-full";
            } else if (viewId === 'about') {
                document.getElementById('view-about').classList.remove('hidden');
                expBtn.className = "text-[#FF5E00] px-4 py-2 font-inter tracking-widest uppercase text-xs font-bold neumorphic-sunken active-tab rounded-full";
            }
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function switchCurrency(currency) {
            currentCurrency = currency;
            document.querySelectorAll('[data-currency]').forEach(el => el.classList.toggle('active-tab', el.getAttribute('data-currency') === currency));
            document.getElementById('hero-managed-spend').textContent = formatCurrency(841000) + '+';
            updateAdsContent();
        }

        function switchBudget(tier) {
            currentBudget = tier;
            document.querySelectorAll('[data-budget]').forEach(el => el.classList.toggle('active-tab', el.getAttribute('data-budget') === tier));
            updateAdsContent();
        }

        function updateAdsContent() {
            const data = adsData[currentBudget];
            if(!document.getElementById('val-spend')) return;
            
            document.getElementById('val-spend').textContent = formatCurrency(data.spend);
            document.getElementById('val-2').textContent = data.kpi2_val.toLocaleString();
            document.getElementById('val-3').textContent = data.kpi3_val.toLocaleString();
            document.getElementById('val-insight').textContent = translations[currentLang][data.insight];
            
            document.getElementById('kpi-label-2').textContent = translations[currentLang][data.kpi2_lbl];
            document.getElementById('kpi-label-3').textContent = translations[currentLang][data.kpi3_lbl];

            const tableBody = document.getElementById('table-body');
            tableBody.innerHTML = '';
            data.table.forEach(row => {
                const tr = document.createElement('tr');
                tr.className = 'border-b border-black/5 last:border-0 hover:bg-black/5';
                tr.innerHTML = `<td class="py-2">${translations[currentLang][row.m] || row.m}</td><td class="py-2 font-bold text-right text-primary">${row.isCurrency ? formatCurrency(row.v) : row.v}</td>`;
                tableBody.appendChild(tr);
            });
        }

        const cursor = document.getElementById('custom-cursor');
        const cursorGlow = document.getElementById('cursor-glow');
        if(cursor && cursorGlow) {
            document.addEventListener('mousemove', (e) => {
                cursor.style.left = e.clientX + 'px';
                cursor.style.top = e.clientY + 'px';
                cursorGlow.style.left = e.clientX + 'px';
                cursorGlow.style.top = e.clientY + 'px';
            });
            document.querySelectorAll('a, button, input, textarea, .flip-card, h1, h2, .group\\/avatar').forEach(el => {
                el.addEventListener('mouseenter', () => { cursor.classList.add('expanded'); cursorGlow.classList.add('expanded'); });
                el.addEventListener('mouseleave', () => { cursor.classList.remove('expanded'); cursorGlow.classList.remove('expanded'); });
            });
        }

        showView('main');
</script>
